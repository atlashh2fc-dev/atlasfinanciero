NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Dominio canónico usado por los correos de acceso en producción.
# En desarrollo puede omitirse: la aplicación usa el origen de la solicitud.
APP_URL=https://atlasfinanciero.vercel.app

# Sólo servidor. Permite a un Administrador invitar usuarios desde Atlas.
# Usa una Secret Key actual (sb_secret_...) o, sólo por compatibilidad, Service Role.
SUPABASE_SECRET_KEY=

# ChileCompra / Mercado Público. Sólo servidor: permite reemplazar el ticket
# documental público por el ticket propio solicitado en chilecompra.cl/api/.
CHILECOMPRA_API_TICKET=

# PeopleWork. Estas variables son exclusivas del servidor: nunca usar el prefijo
# NEXT_PUBLIC_ ni incluir valores reales en Git. La URL, método de autenticación
# y endpoint se completan desde la documentación o soporte de PeopleWork.
PEOPLEWORK_API_BASE_URL=
PEOPLEWORK_API_KEY=
PEOPLEWORK_SECRET_KEY=
PEOPLEWORK_PAYROLL_COSTS_PATH=
PEOPLEWORK_AUTH_SCHEME=
